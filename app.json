{
  "name": "WordSeek",
  "description": "A Wordle-inspired word guessing Telegram bot",
  "repository": "https://github.com/harshkingxmdb/WordSeek",
  "keywords": ["telegram", "bot", "wordle", "game", "bun"],
  "buildpacks": [
    { "url": "https://github.com/jakeg/heroku-buildpack-bun" }
  ],
  "addons": [
    "heroku-postgresql:essential-0",
    "heroku-redis:mini"
  ],
  "env": {
    "BOT_TOKEN": {
      "description": "Your Telegram Bot Token from @BotFather",
      "value": "",
      "required": true
    },
    "DAILY_WORDLE_SECRET": {
      "description": "Secret key for daily Wordle signature/verification",
      "value": "",
      "required": true
    },
    "DAILY_WORDLE_START_DATE": {
      "description": "Starting date for daily Wordle rotation (YYYY-MM-DD)",
      "value": "2025-01-01"
    },
    "NODE_ENV": {
      "description": "Environment mode",
      "value": "production"
    },
    "ADMIN_USERS": {
      "description": "Comma-separated list of Telegram User IDs with admin privileges",
      "value": "",
      "required": true
    },
    "TIME_ZONE": {
      "description": "Used for Daily Wordle reset time",
      "value": "Asia/Kathmandu"
    },
    "SUGGESTIONS_CHANNEL": {
      "description": "Suggested words channel (optional)",
      "value": "",
      "required": false
    },
    "LOGS_CHANNEL": {
      "description": "Bot logs channel (optional)",
      "value": "",
      "required": false
    },
    "GEMINI_API_KEYS": {
      "description": "Gemini API keys, comma separated if multiple (optional)",
      "value": "",
      "required": false
    }
  },
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  }
  }
